[flake8]
max-line-length = 100
ignore = E501,F401,F403,F405,F541,F841,W503,W504,E226,E402,E722
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .tox,
    .eggs,
    *.egg,
    build,
    dist
per-file-ignores =
    client/behavior_tree/__init__.py:F401,F403,F405
    */tests/*:F401,F841
    examples/*:F401,F841
