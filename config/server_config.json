{
  "server": {
    "host": "127.0.0.1",
    "port": 5555,
    "monitor_port": 8080,
    "max_clients": 100,
    "client_timeout": 30.0,
    "heartbeat_interval": 5.0
  },
  "game_settings": {
    "tick_rate": 60,
    "world_update_rate": 10,
    "agent_decision_rate": 2,
    "physics_enabled": true,
    "collision_detection": true
  },
  "world_rules": {
    "movement": {
      "max_speed": 200.0,
      "default_speed": 50.0,
      "run_multiplier": 2.0,
      "bounds_checking": true,
      "collision_checking": true
    },
    "combat": {
      "default_attack_range": 5.0,
      "default_attack_cooldown": 1.0,
      "friendly_fire": false,
      "auto_target": false,
      "experience_on_kill": true
    },
    "interaction": {
      "default_interaction_range": 10.0,
      "require_line_of_sight": false,
      "interaction_cooldown": 0.5
    },
    "resources": {
      "auto_collect": false,
      "collection_time": 2.0,
      "shared_nodes": true,
      "depletion_enabled": true
    }
  },
  "validation": {
    "strict_movement": true,
    "anti_cheat": {
      "speed_checking": true,
      "teleport_detection": true,
      "action_rate_limiting": true,
      "max_actions_per_second": 10
    },
    "bounds": {
      "world_boundaries": true,
      "safe_zone_enforcement": true,
      "terrain_restrictions": true
    }
  },
  "persistence": {
    "auto_save_interval": 30.0,
    "snapshot_interval": 300.0,
    "save_directory": "output/persistence",
    "backup_count": 5,
    "compress_saves": false
  },
  "logging": {
    "level": "INFO",
    "log_directory": "output/logs",
    "log_actions": true,
    "log_connections": true,
    "log_combat": true,
    "log_trading": true,
    "performance_metrics": true
  },
  "ai_settings": {
    "npc_update_interval": 1.0,
    "enemy_ai_enabled": true,
    "pathfinding_enabled": true,
    "dynamic_difficulty": false,
    "spawn_balancing": true
  },
  "experimental": {
    "machine_learning": false,
    "advanced_pathfinding": false,
    "weather_system": false,
    "day_night_cycle": false
  }
}